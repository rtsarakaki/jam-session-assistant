# Supabase — server-only (do not use NEXT_PUBLIC_ for these)
# Copy to .env.local. Keys: Dashboard → Project Settings → API (or Connect dialog).
# Naming matches current Supabase docs (publishable / secret); legacy JWT names still work.
# @see https://supabase.com/docs/guides/api/api-keys

# Optional: canonical public URL of this app (production or preview). Use when OAuth
# redirects to localhost on the host — must match what users open in the browser.
# Same value can be set as NEXT_PUBLIC_SITE_URL if you already use it elsewhere.
# APP_ORIGIN=https://your-deployment.vercel.app

SUPABASE_URL=https://your-project.supabase.co

# Recommended (new keys, e.g. sb_publishable_...)
SUPABASE_PUBLISHABLE_KEY=

# Legacy JWT "anon" key — same privilege as publishable; use if your project has not migrated yet
# SUPABASE_ANON_KEY=

# Optional admin client (bypasses RLS). Prefer new secret key (sb_secret_...):
# SUPABASE_SECRET_KEY=
# Legacy JWT:
# SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Dashboard → Authentication → Providers → Google):
# - Enable Google and paste Client ID / Secret from Google Cloud Console.
# - Authentication → URL Configuration:
#   - Site URL: your real app URL in production (e.g. https://<project>.vercel.app), not localhost.
#   - Redirect URLs: include every callback you use, e.g.
#     http://localhost:3000/auth/callback
#     https://<your-domain>/auth/callback
#     https://<preview-branch>-<team>.vercel.app/auth/callback (optional, for previews)
# - Google Cloud → Credentials → OAuth client → Authorized redirect URIs: use the
#   Supabase callback URL shown on the Google provider page (…/auth/v1/callback).

# Test connection (with dev server running: npm run dev):
#   curl -s http://localhost:3000/api/supabase/health
# Or open the same URL in the browser.

# Optional local-only auth bypass (dev convenience):
# When enabled in localhost, unauthenticated /app requests auto-login using these credentials.
# Never use in production.
# DEV_AUTH_BYPASS_ENABLED=1
# DEV_AUTH_BYPASS_EMAIL=rtsarakaki@example.com
# DEV_AUTH_BYPASS_PASSWORD=your-dev-password
