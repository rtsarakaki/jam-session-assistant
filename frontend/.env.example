# Supabase — server-only (do not use NEXT_PUBLIC_ for these)
# Copy to .env.local. Keys: Dashboard → Project Settings → API (or Connect dialog).
# Naming matches current Supabase docs (publishable / secret); legacy JWT names still work.
# @see https://supabase.com/docs/guides/api/api-keys

SUPABASE_URL=https://your-project.supabase.co

# Recommended (new keys, e.g. sb_publishable_...)
SUPABASE_PUBLISHABLE_KEY=

# Legacy JWT "anon" key — same privilege as publishable; use if your project has not migrated yet
# SUPABASE_ANON_KEY=

# Optional admin client (bypasses RLS). Prefer new secret key (sb_secret_...):
# SUPABASE_SECRET_KEY=
# Legacy JWT:
# SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Dashboard → Authentication → Providers → Google):
# - Enable Google and paste Client ID / Secret from Google Cloud Console.
# - Authentication → URL Configuration → Redirect URLs: include your app callback, e.g.
#     http://localhost:3000/auth/callback
#     https://<your-domain>/auth/callback
# - Google Cloud → Credentials → OAuth client → Authorized redirect URIs: use the
#   Supabase callback URL shown on the Google provider page (…/auth/v1/callback).

# Test connection (with dev server running: npm run dev):
#   curl -s http://localhost:3000/api/supabase/health
# Or open the same URL in the browser.
